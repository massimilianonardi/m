#!/bin/bash

browse_dir__()
{
  dir="$1"
  dir="$(cd -L -- "$dir" && pwd -L)"
  cd "$dir"
  echo "--------------------------------------------------------------------------------"
  echo "$dir"
  echo "--------------------------------------------------------------------------------"
  FILES_ARRAY=("..")
  echo "${FILES_ARRAY[0]}"
  for k in *
  do
    echo "$k" 1>&2
    FILES_ARRAY+=("$k")
  done

  echo "--------------------------------------------------------------------------------"
  echo "number of items: ${#FILES_ARRAY[@]}"
  echo "--------------------------------------------------------------------------------"
}

load_dir()
{
  DIR="$1"
  DIR="$(cd -L -- "$DIR" && pwd -L)"
  cd "$DIR"

  FILES_ARRAY=("..")
  for k in *
  do
    FILES_ARRAY+=("$k")
  done
}

browse_dir()
{
  ROWS="$(tput lines)"
  ROWS="$((ROWS-12))"
  COLS="$(tput cols)"
  COUNT=0
  for k in ${FILES_ARRAY[@]}
  do
    echo "$k" 1>&2
    COUNT=$((COUNT+1))
    if [ ! "$COUNT" -lt "$ROWS" ]
    then
      break
    fi
  done

  echo "--------------------------------------------------------------------------------"
  echo "$DIR"
  echo "--------------------------------------------------------------------------------"
  echo "number of items: ${#FILES_ARRAY[@]}"
  echo "--------------------------------------------------------------------------------"

  tput cup 0 0
}

scroll_dir()
{
  tput clear
  ROWS="$(tput lines)"
  ROWS="$((ROWS-12))"
  COLS="$(tput cols)"
  tput cup 0 0

  INDEX_START=$1
  # INDEX_END=$((${#FILES_ARRAY[@]}-12))
  INDEX_END=$((ROWS-6+$1))
  # echo "start $INDEX_START"
  # echo "end $INDEX_END"
  # return
  for (( i=INDEX_START; i<INDEX_END; i++ ));
  do
    echo "${FILES_ARRAY[i]}" 1>&2
  done

  echo "--------------------------------------------------------------------------------"
  echo "$DIR"
  echo "--------------------------------------------------------------------------------"
  echo "number of items: ${#FILES_ARRAY[@]}"
  echo "--------------------------------------------------------------------------------"

  tput cup 0 0
}

update_screen_vars()
{
  ROWS="$(tput lines)"
  ROWS="$((ROWS-6))"
  COLS="$(tput cols)"
}

update_screen_list()
{
  update_screen_vars
  tput clear
  tput cup 0 0

  INDEX_START=$1
  INDEX_END=$((ROWS+$1))
  for (( i=INDEX_START; i<INDEX_END; i++ ));
  do
    echo "${FILES_ARRAY[i]}" 1>&2
  done

  echo "--------------------------------------------------------------------------------"
  echo "$DIR"
  echo "--------------------------------------------------------------------------------"
  echo "number of items: ${#FILES_ARRAY[@]}"
  echo "--------------------------------------------------------------------------------"

  tput cup 0 0
}

scroll_cursor()
{
  FILE_ARRAY_POS=$((FILE_ARRAY_POS + $1))
  # echo "array position raw: $FILE_ARRAY_POS"
  if [ "$FILE_ARRAY_POS" -lt "0" ]
  then
    FILE_ARRAY_POS=0
  elif [ "$FILE_ARRAY_POS" -gt "$((${#FILES_ARRAY[@]} - ROWS -1))" ]
  then
    FILE_ARRAY_POS="$((${#FILES_ARRAY[@]} - ROWS -1))"
  fi
  # echo "array position: $FILE_ARRAY_POS"

  CURSOR_POS=$((CURSOR_POS + $1))
  # echo "cursor position raw: $CURSOR_POS"
  if [ "$CURSOR_POS" -lt "0" ]
  then
    CURSOR_POS=0
  elif [ "$CURSOR_POS" -gt "$(($ROWS - 1))" ]
  then
    CURSOR_POS="$(($ROWS - 1))"
  fi
  # echo "cursor position: $CURSOR_POS"

  update_screen_list $((FILE_ARRAY_POS + CURSOR_POS))

  tput cup $CURSOR_POS 0
}

