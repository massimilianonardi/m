#!/bin/sh

. log.lib.sh

log_debug "rsudo askpass called! ...checking if caller is ssh! RSUDO_PASSWORD $([ -n "$RSUDO_PASSWORD" ] && echo "is exported and not null" || echo "is NOT exported (null)")"
if [ "$(ps -o "comm=" -p "$PPID")" = "ssh" ]
then
  if [ -t 0 ]
  then
    if [ -n "$RSUDO_FIFO" ]
    then
      # delete redundant to ensure removal even on some interruption
      trap "rm -f '$RSUDO_FIFO'" INT QUIT TERM HUP PIPE ABRT TSTP EXIT
      exec 0<"$RSUDO_FIFO"
      read -r RSUDO_PASSWORD
      # delete redundant with main process to ensure removal even on some interruption
      rm -f "$RSUDO_FIFO"
      RSUDO_PASSWORD="$(echo "$RSUDO_PASSWORD" | openssl enc -d -A -base64 | RSUDO_TOKEN="$RSUDO_TOKEN" openssl enc -d -aes-256-cbc -pbkdf2 -pass "env:RSUDO_TOKEN")"
    else
      log_fatal "wrong rsudo-askpass method"
      exit 1
    fi
  else
    read -r RSUDO_PASSWORD
  fi

  echo "$RSUDO_PASSWORD"

  log_debug "rsudo askpass called by ssh! RSUDO_PASSWORD read and $([ -n "$RSUDO_PASSWORD" ] && echo "is not null" || echo "is null")"
  # log_trace "RSUDO_PASSWORD=$RSUDO_PASSWORD"

  if [ -z "$RSUDO_PASSWORD" ]
  then
    log_fatal "password is null!"
    exit 1
  fi
else
  log_fatal "security checkfailed!"
  exit 1
fi
