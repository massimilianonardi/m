#!/bin/sh

# if argument is a link, returns its target, otherwise returns argument as a path (adds ./ to relative paths if omitted)

if [ -L "$1" ]
then
  TARGET=$(ls -ld -- "$1" 2>/dev/null) || exit 1
  # TARGET="$(ls -ld -- "$1")"
  TARGET="${TARGET#*" $1 -> "}"
elif [ -e "$1" ]
then
  TARGET="$1"
  if [ "$TARGET" = "${TARGET#/}" ] && [ "$TARGET" = "${TARGET#./}" ] && [ "$TARGET" = "${TARGET#../}" ]
  then
    TARGET="./$TARGET"
  fi
else
  exit 1
fi

echo "$TARGET"
