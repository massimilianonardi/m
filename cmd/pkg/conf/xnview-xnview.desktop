[Desktop Entry]
Type=Application
Name=XnView MP
Comment=Graphic viewer, browser, converter
Exec=xnview %F
Terminal=false
Icon=xnview-xnview-icon
Categories=Graphics;
StartupNotify=true
StartupWMClass=XnViewMP
MimeType=image/bmp;image/gif;image/jpeg;image/png;image/tiff;image/x-tga;image/x-pcx;image/jp2;
X-AppImage-Version=1.10.5.glibc2.17
