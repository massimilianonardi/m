  # test_log_echo | tee /tmp/log_stdout.log
  # test_log_echo 3>&2 2>&1 1>&3 | tee /tmp/log_stderr.log 2>&1 1>/dev/null
  # test_log_echo 3>&2 2>&1 1>&3 | tee /tmp/log_stderr.log 2>/dev/null 1>/dev/null
