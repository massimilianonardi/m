#!/bin/sh

#-------------------------------------------------------------------------------

test_log_echo()
{
  echo "out: message 1"
  echo "err: error 1"  1>&2
  echo "out: message 2"
  echo "err: error 2"  1>&2
  echo "out: message 3"
  echo "err: error 3"  1>&2
  echo "err: error 4"  1>&2
  echo "out: message 4"
  echo "out: message 5"
  echo "err: error 5"  1>&2
  echo "out: message 6"
  echo "err: error 6"  1>&2
}

#-------------------------------------------------------------------------------

test_log()
{
  . log.lib.sh

  LOG_LEVEL="all"
  log_warn "test command warn"
  echo ""
  # test_log_echo
  # test_log_echo 1>/tmp/log_stdout.log 2>/tmp/log_stderr.log
  # test_log_echo | tee /tmp/log_stdout.log
  # test_log_echo 3>&2 2>&1 1>&3 | tee /tmp/log_stderr.log 2>&1 1>/dev/null
  # test_log_echo 3>&2 2>&1 1>&3 | tee /tmp/log_stderr.log 2>/dev/null 1>/dev/null
  # test_log_echo 3>&2 2>&1 1>&3 | tee /tmp/log_stderr.log 2>&1 1>/dev/null | tee /tmp/log_stdout.log 1>/dev/null
  # test_log_echo | tee /tmp/log_stdout.log 2>/tmp/log_stderr.log
  # test_log_echo 2>/tmp/log_stderr.log | tee /tmp/log_stdout.log 1>/dev/null
  # test_log_echo | <&1 tee /tmp/log_stdout.log | <&2 tee /tmp/log_stderr.log

  cat << 'EOF' > /tmp/log_test
  echo "out: message 1"
  echo "err: error 1"  1>&2
  echo "out: message 2"
  echo "err: error 2"  1>&2
  echo "out: message 3"
  echo "err: error 3"  1>&2
  echo "err: error 4"  1>&2
  echo "out: message 4"
  echo "out: message 5"
  echo "err: error 5"  1>&2
  echo "out: message 6"
  echo "err: error 6"  1>&2
EOF

  # cat /tmp/log_test
  chmod +x /tmp/log_test
  # /tmp/log_test
  # log -l all -- /tmp/log_test
  # log -l all -d /tmp -- /tmp/log_test
  # log -l all -d /tmp -n myname -- /tmp/log_test
  # log -l all -n myname -- /tmp/log_test
  # log -l all -u -- /tmp/log_test
  # log -l all -n myname -u -- /tmp/log_test
  log -l all -d /tmp -n myname -u -- /tmp/log_test

  echo "OUTPUT FILES:"
  echo "log_stdout:"
  cat /tmp/log_stdout.log
  echo "log_stderr:"
  cat /tmp/log_stderr.log
  echo "log_stdall:"
  cat /tmp/log_stdall.log

  rm -f /tmp/log_stdout.log
  rm -f /tmp/log_stderr.log
  rm -f /tmp/log_stdall.log
  rm -f /tmp/*.log
  rm -f /tmp/log_test
}

#-------------------------------------------------------------------------------
