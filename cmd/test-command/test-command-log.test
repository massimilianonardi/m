  cat << 'EOF' > /tmp/log_test
  echo "out: message 1"
  echo "err: error 1"  1>&2
  echo "out: message 2"
  echo "err: error 2"  1>&2
  echo "out: message 3"
  echo "err: error 3"  1>&2
