#!/bin/sh

#-------------------------------------------------------------------------------

test_log_echo()
{
  echo "out: message 1"
  echo "err: error 1"  1>&2
  echo "out: message 2"
  echo "err: error 2"  1>&2
  echo "out: message 3"
  echo "err: error 3"  1>&2
  echo "err: error 4"  1>&2
  echo "out: message 4"
  echo "out: message 5"
  echo "err: error 5"  1>&2
  echo "out: message 6"
  echo "err: error 6"  1>&2
}

#-------------------------------------------------------------------------------

test_log()
{
  . log.lib.sh

