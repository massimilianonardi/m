  # log -l all -d /tmp --bad-option -- /tmp/log_test
  log

  echo "EXIT_CODE=$?"

  echo "OUTPUT FILES:"
  cat /tmp/*.log

  rm -f /tmp/*.log
  rm -f /tmp/log_test

