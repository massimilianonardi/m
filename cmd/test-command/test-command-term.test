  export MENU_HEADER="$(printf "Menu Header - ROW 1\n---Row 2---\n---Row 3---\n\n")"
  export MENU_FOOTER="$(printf "Menu Footer - ROW 1\n---Row 2---")"

  # menucmd id menucmd multi menucmd keys "b:n:m" \

