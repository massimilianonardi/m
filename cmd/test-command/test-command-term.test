  # echo "key=$key"; echo "res=$res"; echo "selection=$selection"
  # fsencdec

  # term-mod menu $menu_entries

  # menuexec "" "" "" term-mod menu $menu_entries
  # echo "key=$key"; echo "res=$res"; echo "selection=$selection"
  res="$(term-mod menu $menu_entries)"
  echo "res=$res"

  # term-mod head "$MENU_HEADER" "$MENU_FOOTER" term-mod-menu $menu_entries
  # res="$(term-mod head "$MENU_HEADER" "$MENU_FOOTER" term-mod-menu $menu_entries)"
  # echo "res=$res"

