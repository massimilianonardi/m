#-------------------------------------------------------------------------------

init_menu_dir()
{
  if [ ! -d "$1" ]
  then
    return 1
  fi

  cd "$1"
  set -- "$(cd -L -- "$1" && pwd -L)"

  array DIR_ARRAY

  if [ "$(pwd)" = "/" ]
  then
    set -- ""
  else
    array DIR_ARRAY add "${1}/..=.."
  fi

  for k in ..?* .[!.]* *
  do
    if [ -e "$k" ]
    then
      # array DIR_ARRAY add "${1}/$k=$k"
      if [ -d "$k" ]
      then
        array DIR_ARRAY add "${1}/$k=[D] $k"
      elif [ -f "$k" ]
      then
        array DIR_ARRAY add "${1}/$k=[F] $k"
      fi
    fi
  done

  # eval menuread "key" "file" "selection" $(array DIR_ARRAY get)
  # array FILE_SELECTION add "$selection"
  #
  # array DIR_ARRAY unset
}

#-------------------------------------------------------------------------------

env_defaults()
{
  true
  # set proper initial variables values
}

args_init()
{
  init_menu_dir "$@"
}

render()
{
  eval KEY_LOOP="false" tui-menu $(array DIR_ARRAY get)
}


key_loop()
{
  key="enter"
  res="$(pwd)"

  while [ "$key" = "enter" ] && [ -d "$res" ]
  do
    term_region_clear
    eval menuexec key res selection tui-menu $(array DIR_ARRAY get)

    if [ -z "$res" ]
    then
      return 0
    elif [ "$key" = "enter" ]
    then
      true
      # add selection to global selection in easy way to recall for such dir
      if [ -d "$res" ]
      then
        # pass eventual previous selection for new dir
        init_menu_dir "$res"
      fi
    else
      true
      # return custom key pressed and global selection
    fi

    # if [ ! "$key" = "enter" ]
