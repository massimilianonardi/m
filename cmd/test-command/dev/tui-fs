#!/bin/sh

#-------------------------------------------------------------------------------

. env.lib.sh
. term.lib.sh

. array.lib.sh
. menu.lib.sh

#-------------------------------------------------------------------------------

menu_dir()
{
  if [ ! -d "$1" ]
  then
    return 1
  fi

  cd "$1"
  set -- "$(cd -L -- "$1" && pwd -L)"

  array DIR_ARRAY

  if [ "$(pwd)" = "/" ]
  then
    set -- ""
  else
    array DIR_ARRAY add "${1}/..=.."
  fi

  for k in ..?* .[!.]* *
  do
    if [ -e "$k" ]
    then
      # array DIR_ARRAY add "${1}/$k=$k"
      if [ -d "$k" ]
      then
        array DIR_ARRAY add "${1}/$k=[D] $k"
      elif [ -f "$k" ]
      then
        array DIR_ARRAY add "${1}/$k=[F] $k"
      fi
    fi
  done

  # eval menuread "key" "file" "selection" $(array DIR_ARRAY get)
  # array FILE_SELECTION add "$selection"
  #
  # array DIR_ARRAY unset
}

#-------------------------------------------------------------------------------

env_defaults()
{
  true
  # set proper initial variables values
}

args_init()
{
  menu_dir "$@"
}

render()
{
  eval KEY_LOOP="false" tui-menu $(array DIR_ARRAY get)
}

key_loop()
{
  while true
  do
    term_region_clear
    eval menuexec key res selection tui-menu $(array DIR_ARRAY get)

    if [ -z "$res" ]
    then
      return 0
    fi

    # if res is null then q or esc was pressed
    # else enter was pressed (space for toggle is handled by tui-menu internally)
    # then add returned selection to global selection and if res is a directory,
    # then load newly selected dir and find a way to pass that dir selection to next call to tui-menu
    # a possible way is to save all tui-menu state for each browsed dir, but may lead to huge memory usage

    case "$key" in
      "q") return 0;;
      "esc") return 0;;
      # "space") select_item_toggle;;
      "enter") menu_dir "$res";;
      # *) check_key "$key";;
    esac
  done
}

env_list_get()
{
  env_list "term_ROW\|term_COL\|term_FS_"
}

#-------------------------------------------------------------------------------

. tui-main.src.sh
