#!/bin/sh

# MENU_ID="false" # disables id detection from menu entries "menu_entry_id=menu_entry_text"
# MENU_MULTISELECTION="true" # enables multi selection
# ROW_0 # row coordinate to start render
# COL_0 # col coordinate to start render
# ROWS # max rows to render
# COLS # max cols to render
# MENU_CUSTOM_KEYS="key1:key2:key3" # returns selection also with these keys in the form "key:selection"
# MENU_HEADER # text above menu
# MENU_FOOTER # text below menu

#-------------------------------------------------------------------------------

. env.lib.sh
. array.lib.sh
. term.lib.sh

#-------------------------------------------------------------------------------

string_count_lines()
{
  if [ -z "$1" ]
  then
    return 1
  fi

  eval echo "\$(($(printf "${1}" | wc -l) + 1))"
}

#-------------------------------------------------------------------------------

screen_vars_update()
{
  # init render region
  if [ -z "$term_mod_ROW0" ]
  then
    term_mod_ROW0="0"
  fi

  if [ -z "$term_mod_COL0" ]
  then
    term_mod_COL0="0"
  fi

  if [ -z "$term_mod_ROWS" ]
  then
    term_mod_ROWS="$TERM_ROWS"
  fi

  if [ -z "$term_mod_COLS" ]
  then
    term_mod_COLS="$TERM_COLS"
  fi

  # init header/footer
  if [ -n "$m_menu_MENU_HEADER" ]
  then
    m_menu_MENU_HEADER_SIZE_ROW="$(string_count_lines "$m_menu_MENU_HEADER")"

    if [ -z "$m_menu_MENU_HEADER_ROW_0" ]
    then
      m_menu_MENU_HEADER_ROW_0="$term_mod_ROW0"
      term_mod_ROW0="$(($term_mod_ROW0 + $m_menu_MENU_HEADER_SIZE_ROW))"
    fi

    if [ -z "$m_menu_MENU_HEADER_COL_0" ]
    then
      m_menu_MENU_HEADER_COL_0="$term_mod_COL0"
    fi
  fi

  if [ -n "$m_menu_MENU_FOOTER" ]
  then
    m_menu_MENU_FOOTER_SIZE_ROW="$(string_count_lines "$m_menu_MENU_FOOTER")"

    if [ -z "$m_menu_MENU_FOOTER_ROW_0" ]
    then
      term_mod_ROWS="$(($term_mod_ROWS - $m_menu_MENU_FOOTER_SIZE_ROW))"
      m_menu_MENU_FOOTER_ROW_0="$(($term_mod_ROW0 + $term_mod_ROWS))"
    fi

    if [ -z "$m_menu_MENU_FOOTER_COL_0" ]
    then
      m_menu_MENU_FOOTER_COL_0="$term_mod_COL0"
    fi
  fi

  # init limits
  if [ -z "$term_mod_ROWS_MIN" ]
  then
    term_mod_ROWS_MIN="2"
  fi

  if [ -z "$m_menu_MENU_ENTRY_SIZE_MIN" ]
  then
    m_menu_MENU_ENTRY_SIZE_MIN="3"
  fi

  if [ "$term_mod_ROW0" -gt "$(($TERM_ROWS - 1 - $term_mod_ROWS_MIN))" ]
  then
    term_mod_ROW0="$(($TERM_ROWS - 1 - $term_mod_ROWS_MIN))"
  fi

  if [ "$term_mod_COL0" -gt "$(($TERM_COLS - 1 - $m_menu_MENU_ENTRY_SIZE_MIN))" ]
  then
    term_mod_COL0="$(($TERM_COLS - 1 - $m_menu_MENU_ENTRY_SIZE_MIN))"
  fi

  if [ "$(($term_mod_ROW0 + $term_mod_ROWS))" -gt "$TERM_ROWS" ]
  then
    term_mod_ROWS="$(($TERM_ROWS - $term_mod_ROW0))"
  fi

  if [ "$(($term_mod_COL0 + $term_mod_COLS))" -gt "$TERM_COLS" ]
  then
    term_mod_COLS="$(($TERM_COLS - $term_mod_COL0))"
  fi

  # init menu id detection
  if [ -z "$m_menu_MENU_ID" ]
  then
    m_menu_MENU_ID="true"
  fi

  # init multi selection
  if [ -z "$m_menu_MENU_MULTISELECTION" ]
  then
    m_menu_MENU_MULTISELECTION="false"
  fi

  if [ -z "$m_menu_SEL_ITEM_TRUE_STRING" ]
  then
    m_menu_SEL_ITEM_TRUE_STRING="+"
  fi

  if [ -z "$m_menu_SEL_ITEM_FALSE_STRING" ]
  then
    m_menu_SEL_ITEM_FALSE_STRING="-"
  fi

  # return key pressed
  if [ -z "$m_menu_MENU_KEY_SEPARATOR" ]
  then
    m_menu_MENU_KEY_SEPARATOR=":"
  fi
}

