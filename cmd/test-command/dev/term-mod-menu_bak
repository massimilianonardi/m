  if [ -n "$m_menu_MENU_CUSTOM_KEYS" ]
  then
    term_output quote "${key}"
    term_output printf " "
    term_output quote "$(array m_menu_MENU_IDS get "$m_menu_ARRAY_POS")"
    term_output printf " "
  fi

  if [ ! "$m_menu_MENU_MULTISELECTION" = "true" ]
  then
    term_output array m_menu_MENU_IDS get "$m_menu_ARRAY_POS"
  else
    array m_menu_MENU_SELECTED_ITEMS
