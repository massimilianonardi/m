menu_dir___()
{
  if [ ! -d "$1" ]
  then
    return 1
  fi

  eval menuctl multi menukeys key index selection "$keys" $(
    cd "$1"
    set -- "$(cd -L -- "$1" && pwd -L)"

    array DIR_ARRAY

    if [ ! "$(pwd)" = "/" ]
    then
      array DIR_ARRAY add "${1}/..=.."
    else
      set -- ""
    fi

    for k in ..?* .[!.]* *
    do
      if [ -e "$k" ]
      then
        array DIR_ARRAY add "${1}/$k=$k"
      fi
    done

    array DIR_ARRAY get

    # FILE="$(eval menu $(array DIR_ARRAY get))"
    #
    # if [ -n "$FILE" ]
    # then
    #   echo "$(cd -L -- "$1" && pwd -L)/$FILE"
    # fi
  )

  echo "key=$key"; echo "index=$index"; echo "selection=$selection"
}

menu_dir()
{
  if [ ! -d "$1" ]
  then
    return 1
  fi

  cd "$1"
  set -- "$(cd -L -- "$1" && pwd -L)"

  array DIR_ARRAY

echo "menu $1"
  if [ ! "$(pwd)" = "/" ]
  then
    array DIR_ARRAY add "${1}/..=.."
  else
    set -- ""
  fi

  for k in ..?* .[!.]* *
  do
    if [ -e "$k" ]
    then
      array DIR_ARRAY add "${1}/$k=$k"
    fi
  done

  eval menuctl multi menukeys key index selection "$keys" $(array DIR_ARRAY get)
  file="$(array DIR_ARRAY get "$index")"
  file="${file%%=*}"

  echo "key=$key"
  echo "index=$index entry=$(array DIR_ARRAY get "$index")"
  echo "file=$file"
  echo "selection=$selection"

  array DIR_ARRAY unset
}

#-------------------------------------------------------------------------------

realpaths

keys="canc:c:d:m:r"

menu_dir "/"

echo "outside"
while [ "$key" = "enter" ] && [ -d "$file" ]
do
echo "inside"
  menu_dir "$file"
done
