menu_dir()
{
  if [ ! -d "$1" ]
  then
    return 1
  fi

  eval menuctl keys key selection "$keys" $(
    cd "$1"
    set -- "$(cd -L -- "$1" && pwd -L)"

    array DIR_ARRAY

    if [ ! "$(pwd)" = "/" ]
    then
      array DIR_ARRAY add "${1}/..=.."
    else
      set -- ""
    fi

    for k in ..?* .[!.]* *
    do
      if [ -e "$k" ]
      then
        array DIR_ARRAY add "${1}/$k=$k"
      fi
    done

    array DIR_ARRAY get

    # FILE="$(eval menu $(array DIR_ARRAY get))"
    #
    # if [ -n "$FILE" ]
    # then
    #   echo "$(cd -L -- "$1" && pwd -L)/$FILE"
    # fi
  )

  echo "key=$key"; echo "selection=$selection"
}

