#!/bin/sh

#-------------------------------------------------------------------------------

array_check()
{
  # eval "[ \"\${${1}}_TYPE\" = \"array\" ]"
  eval "[ \"\$${1}_TYPE\" = \"array\" ]"
}

array_size()
{
  if ! array_check "$1"
  then
    echo "not an array"
    return -1
  fi

  eval "${1}=\"\${${2}}_SIZE\""
}

array_get()
{
  if ! array_check "$1"
  then
    echo "not an array"
    return -1
  fi

  eval "${1}=\"\${${2}}_${3}\""
}

array_set()
{
  if ! array_check "$1"
  then
    echo "not an array"
    return -1
  fi

  eval "${1}=\"\${${2}}_${3}\""
}

array_add()
{
  if ! array_check "$1"
  then
    echo "not an array"
    return -1
  fi

  eval "${1}=\"\${${2}}_${3}\""
}

array_unset()
{
  if ! array_check "$1"
  then
    echo "not an array"
    return -1
  fi

  eval "${1}=\"\${${2}}_${3}\""
}

array___()
{
  case "$1" in
    "size") shift; array_size "$@";;
    "get") shift; array_get "$@";;
    "set") shift; array_set "$@";;
    "add") shift; array_add "$@";;
    "unset") shift; array_unset "$@";;
    *) return -1;;
  esac
}

array__()
{
  eval "[ \"\$${1}_TYPE\" = \"array\" ]"
  if [ ! "$?" = "0" ]
  then
    if [ "$#" = "1" ]
    then
      eval "${1}_TYPE=\"array\""
      eval "${1}_SIZE=\"0\""
      return 0
    else
      echo "not an array!" 1>&2
      exit 1
    fi
  fi

  case "$2" in
    "size")
      eval "${3}=\"\$${1}_SIZE\""
    ;;
    "get")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      eval "${4}=\"\$${1}_${3}\""
    ;;
    "put")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      eval "${1}_${3}=\"\${4}\""
    ;;
    "add")
      eval "set -- \"\$@\" \"\$${1}_SIZE\""
      eval "${1}_${4}=\"${3}\""
      eval "${1}_SIZE=\"\$((\$${1}_SIZE + 1))\""
    ;;
    "ins")
      # todo
      eval "${1}_SIZE=\"\$((\$${1}_SIZE + 1))\""
    ;;
    "rem")
      # todo
      eval "${1}_SIZE=\"\$((\$${1}_SIZE - 1))\""
    ;;
    "set_BAK")
      set -- "$@" "${1}"
      shift 2
      # eval eval "\${$#}_SIZE=\"\$(($# - 1))\""
      eval eval "\${$#}_SIZE=\"0\""
      while [ "$#" -gt "1" ]
      do
        # eval echo "array=\${$#}"
        # echo "nargs=$#"
        # echo "args=$1"
        eval eval eval "\${$#}_\\\${\${$#}_SIZE}=\\\\\\\"\\\\\\\$1\\\\\\\""
        eval eval "\${$#}_SIZE=\"\$((\${$#}_SIZE + 1))\""
        # eval eval echo "\\$\${$#}_SIZE"
        # echo "assignement: \${$#}_\\\$((\\\${\${$#}_SIZE} - $#))=\"test\""
        # eval echo "assignement: \${$#}_\\\${\${$#}_SIZE} - $#=\"test\""
        # eval eval echo "\\\\\\\"assignement: \${$#}_\\\${\${$#}_SIZE} - $# + 1=\"test\"\\\\\\\""
        shift
      done
    ;;
    "set_WORKING")
      eval "${1}_SIZE=\"0\""
      # set -- "$@" "${1}"
      # shift 2
      # eval eval "\${$#}_SIZE=\"0\""
      # while [ "$#" -gt "1" ]
      # while [ "$(eval echo "\$${1}_SIZE")" -lt "$#" ]
      # while eval "[ \"\$${1}_SIZE\" -lt \"$#\" ]"
      # while [ "$(eval echo "\$${1}_SIZE")" -lt "$(($# - 2))" ]
      while eval "[ \"\$${1}_SIZE\" -lt \"\$(($# - 2))\" ]"
      do
        # arraytr $1 \$${1}_SIZE
        # arrayassign $1 \$${1}_SIZE ${$((${1}_SIZE + 2))}
        eval "${1}_TMP=\$((${1}_SIZE + 3))"
        eval eval "${1}_TMP=\\\"\\\${\$${1}_TMP}\\\""
        arrayassign $1 "\$${1}_SIZE" "\$${1}_TMP"
        # arrayassign $1 "\$${1}_SIZE" "\$((${1}_SIZE + 3))"
        # arrayassign $1 "\$${1}_SIZE" "\$$(arrayget $1 "\$${1}_SIZE")"
        # eval eval echo "\$$(arrayget $1 "\$${1}_SIZE")"
        # arrayassign $1 "\$${1}_SIZE" "\\\${\$((${1}_SIZE + 3))}"
        # eval "${1}_TMP=\"${1}_\$${1}_SIZE\""
        # eval echo "tmp: \$${1}_TMP"
        # eval "${1}_TMP2=\"\$${1}_SIZE\""
        # eval echo "tmp2: \\\$\$${1}_TMP2"
        # eval "${1}_${3}=\"\${4}\""
        eval "${1}_SIZE=\"\$((\$${1}_SIZE + 1))\""
        # eval eval "\${$#}_\\\${\${$#}_SIZE}=\\\"$1\\\""
        # eval eval "\${$#}_SIZE=\"\\\$((\${$#}_SIZE + 1))\""
        # shift
      done
      eval "unset ${1}_TMP"
    ;;
    "set")
      array "$1" unset
      array "$1"
      set -- "$@" "${1}"
      shift 2
      while [ "$#" -gt "1" ]
      do
        eval "array \"\$$#\" add \"\$1\""
        shift
      done
    ;;
    "unset")
      eval "set -- \"\$1\" \"\$${1}_SIZE\""
      while [ "$2" -gt "0" ]
      do
        eval "${1}_SIZE=\"\$((\$${1}_SIZE - 1))\""
        eval "set -- \"\$1\" \"\$${1}_SIZE\""
        eval "unset ${1}_${2}"
      done
      eval "unset ${1}_SIZE"
      eval "unset ${1}_TYPE"
    ;;
    *) exit 1;;
  esac
}

array_()
{
  eval "[ \"\$${1}_TYPE\" = \"array\" ]"
  if [ ! "$?" = "0" ]
  then
    if [ "$#" = "1" ]
    then
      eval "${1}_TYPE=\"array\""
      eval "${1}_SIZE=\"0\""
      return 0
    else
      echo "not an array!" 1>&2
      exit 1
    fi
  fi

  case "$2" in
    "size")
      if [ -z "$3" ]
      then
        eval "echo \"\$${1}_SIZE\""
      else
        eval "${3}=\"\$${1}_SIZE\""
      fi
    ;;
    "get")
      if [ -z "$3" ]
      then
        while eval "[ \"\$(($# - 2))\" -lt \"\$${1}_SIZE\" ]"
        do
          set -- "$@" "$(array "$1" get $(($# - 2)))"
        done
        shift 2
        echo "$@"
        return 0
      fi
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      if [ -z "$4" ]
      then
        eval "echo \"\$${1}_${3}\""
      else
        eval "${4}=\"\$${1}_${3}\""
      fi
    ;;
    "put")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      eval "${1}_${3}=\"\${4}\""
    ;;
    "add")
      eval "set -- \"\$@\" \"\$${1}_SIZE\""
      eval "${1}_${4}=\"${3}\""
      eval "${1}_SIZE=\"\$((\$${1}_SIZE + 1))\""
    ;;
    "ins")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      # append to positional args, "$1" "set", then array elems from 0 to index-1,
      # then append new value, then append array elems from index to size-1, shift 3,
      # then call array "$@" that will set array with new elem in right position
      set -- "$@" "$1" "set"
      while [ "$(($# - 6))" -lt "$3" ]
      do
        set -- "$@" "$(array "$1" get $(($# - 6)))"
      done
      set -- "$@" "$4"
      while eval "[ \"\$(($# - 7))\" -lt \"\$${1}_SIZE\" ]"
      do
        set -- "$@" "$(array "$1" get $(($# - 7)))"
      done
      shift 4
      # echo "$@"
      array "$@"
    ;;
    "rem")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      set -- "$@" "$1" "set"
      while [ "$(($# - 5))" -lt "$3" ]
      do
        set -- "$@" "$(array "$1" get $(($# - 5)))"
      done
      while eval "[ \"\$(($# - 4))\" -lt \"\$${1}_SIZE\" ]"
      do
        set -- "$@" "$(array "$1" get $(($# - 4)))"
      done
      shift 3
      # echo "$@"
      array "$@"
    ;;
    "set")
      array "$1" unset
      array "$1"
      set -- "$@" "${1}"
      shift 2
      while [ "$#" -gt "1" ]
      do
        eval "array \"\$$#\" add \"\$1\""
        shift
      done
    ;;
    "unset")
      eval "set -- \"\$1\" \"\$${1}_SIZE\""
      while [ "$2" -gt "0" ]
      do
        eval "${1}_SIZE=\"\$((\$${1}_SIZE - 1))\""
        eval "set -- \"\$1\" \"\$${1}_SIZE\""
        eval "unset ${1}_${2}"
      done
      eval "unset ${1}_SIZE"
      eval "unset ${1}_TYPE"
    ;;
    *) exit 1;;
  esac
}

array()
{
  eval "[ \"\$${1}_TYPE\" = \"array\" ]"
  if [ ! "$?" = "0" ]
  then
    if [ "$#" = "1" ]
    then
      eval "${1}_TYPE=\"array\""
      eval "${1}_SIZE=\"0\""
      return 0
    else
      echo "not an array!" 1>&2
      exit 1
    fi
  fi

  case "$2" in
    "size")
      if [ -z "$3" ]
      then
        eval "echo \"\$${1}_SIZE\""
      else
        eval "${3}=\"\$${1}_SIZE\""
      fi
    ;;
    "get")
      if [ -z "$3" ]
      then
        while eval "[ \"\$(($# - 2))\" -lt \"\$${1}_SIZE\" ]"
        do
          set -- "$@" "$(array "$1" get $(($# - 2)))"
        done
        shift 2
        echo "$@"
        return 0
      fi
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      if [ -z "$4" ]
      then
        eval "echo \"\$${1}_${3}\""
      else
        eval "${4}=\"\$${1}_${3}\""
      fi
    ;;
    "put")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      eval "${1}_${3}=\"\${4}\""
    ;;
    "add")
      eval "set -- \"\$@\" \"\$${1}_SIZE\""
      eval "${1}_${4}=\"${3}\""
      eval "${1}_SIZE=\"\$((\$${1}_SIZE + 1))\""
    ;;
    "ins")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      set -- "$@" "$1" "set"
      while [ "$(($# - 6))" -lt "$3" ]
      do
        set -- "$@" "$(array "$1" get $(($# - 6)))"
      done
      set -- "$@" "$4"
      while eval "[ \"\$(($# - 7))\" -lt \"\$${1}_SIZE\" ]"
      do
        set -- "$@" "$(array "$1" get $(($# - 7)))"
      done
      shift 4
      array "$@"
    ;;
    "rem")
      eval "[ \"${3}\" -lt \"\$${1}_SIZE\" ] || exit 1"
      set -- "$@" "$1" "set"
      while [ "$(($# - 5))" -lt "$3" ]
      do
        set -- "$@" "$(array "$1" get $(($# - 5)))"
      done
      while eval "[ \"\$(($# - 4))\" -lt \"\$${1}_SIZE\" ]"
      do
        set -- "$@" "$(array "$1" get $(($# - 4)))"
      done
      shift 3
      array "$@"
    ;;
    "set")
      array "$1" unset
      array "$1"
      set -- "$@" "${1}"
      shift 2
      while [ "$#" -gt "1" ]
      do
        eval "array \"\$$#\" add \"\$1\""
        shift
      done
    ;;
    "unset")
      eval "set -- \"\$1\" \"\$${1}_SIZE\""
      while [ "$2" -gt "0" ]
      do
        eval "${1}_SIZE=\"\$((\$${1}_SIZE - 1))\""
        eval "set -- \"\$1\" \"\$${1}_SIZE\""
        eval "unset ${1}_${2}"
      done
      eval "unset ${1}_SIZE"
      eval "unset ${1}_TYPE"
    ;;
    *) exit 1;;
  esac
}

test_array()
{
  # array ARRAY_NAME [size|get|set|add|unset] args...
  # array ARRAY_NAME size SIZE_VAR_NAME
  # array ARRAY_NAME get INDEX ELEM_VAR_NAME
  # array ARRAY_NAME put INDEX NEW_VALUE
  # array ARRAY_NAME add NEW_VALUE
  # array ARRAY_NAME ins INDEX NEW_VALUE
  # array ARRAY_NAME rem INDEX
  # array ARRAY_NAME set NEW_VALUES...

  array myarray
  array myarray add "added value"
  array myarray add "added value 2"
  array myarray size
  array myarray add "added value 3"
  array myarray size myarr_size; echo "myarr_size=$myarr_size"
  array myarray put 2 "replaced value"
  array myarray get 1
  array myarray get 1 myvar; echo "myvar=$myvar"
  set | grep myarray
  array myarray set "new val 0" "new val 1" "new val 2" "new val 3" "new val 4"
  set | grep myarray
  array myarray ins 2 "inserted value"
  set | grep myarray
  array myarray rem 1
  set | grep myarray
  array myarray get
  array myarray unset
  echo "array unset"
  set | grep myarray
}

