#!/bin/sh

# rscmd (rscmd db get, rscmd fs put, rscmd apisix route_create) rsudo-command: high level commands on filesystem, db, network, apisix (autoget apikey), keycloak, etc. -> think about pluggable modules
# rsudo rse rsudo-execute: base low level command execution needs evn vars set, it sets ssh_askpass to $0
# rsctl rsudo-ctl: asks for pass if not set (simple), manages credentials import and mapping (rse, rsn, resolve_name, etc.), jobs and scheduling
# rsudo should implement interactive ssh+sudo without asking password twice (because password to ssh canot be intercepted easily)
# maybe using non interactive to save ssh keys and then connect passwordless (if allowed by sshd)
#
# rsudo-env provided by lib import to manage environment, otherwise similar command that chains commands
# rsudo-env-cmd $host $user $@
#
# rsudo-env load credentials-file.enc
# rsudo-env set my_server
# rsudo ls -la
# rsudo-cmd fs get /my/server/path /my/local/path
#
# rsudo.lib.sh: rsudopass (ask securely for pass to user), rsudochenv name (sets env vars from name), rsudoload (alias of encoded_file_import)
# commands: rsudo (base non interactive command), rsudo-cmd (high level commands), rsudo-env (same functionalities of lib)
# rsudoi (interactive using ssh keys) -> separate base command or provided by rsudo-cmd, or inside rsudo and activated by env var?
# rsudox (integrate everything)
# rsudox -- or exec $@ === rsudo $@
# rsudox env $@ === rsudo-env $@ -> -u user, -h host, -l file, -n vars_name_suffix -- rsudox_args
# rsudox fs $@ === rsudo-cmd fs $@
# NO: rsudox env host [user:=$USER] -- rsudox_args -> if password is null, prompts for it -> rsudox rsudox_args
# rsudox env host user rsudox_args (allows -- instead of exec to call base rsudo -> cleaner)
#
# rsudox [--] | --env | --fs | --db-pg -> if $1 don't match any switch or -- then pass all to base rsudo

