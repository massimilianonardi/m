  # basic_regular_expression "-abcd"
  # basic_regular_expression "--abcd"
  # basic_regular_expression "-ab-cd"
  # basic_regular_expression "-ab--cd"
  # basic_regular_expression "-ab+cd"
  basic_regular_expression "-abcd" "b"
}

