#!/bin/bash

#-------------------------------------------------------------------------------

find()
(
  for k in $(find_pkg "$@")
  do
    log_info "${k#$NET_M_PKG_DIR/}"
    echo "${k#$NET_M_PKG_DIR/}"
#    echo "$k"
  done
)

#-------------------------------------------------------------------------------

find_pkg()
(
  for k in "$@"
  do
    net find "$NET_M_PKG_DIR/$k"
#    if [ "$k" = "${k#/}" ]
#    then
#      net find "$NET_M_PKG_DIR/$k"
#    else
#      net find "$k"
#    fi
  done
)

#-------------------------------------------------------------------------------

match_pkg()
{
  log_debug "match_pkg $@"

  parse_pkg "$1"

  for k in "$DATA_DIR/$PKG_NAME/ver/$PKG_PLATFORM"/*
  do
    TMP_VERSION="${k##*/}"
    log_trace "match_pkg - $k - TMP_VERSION=$TMP_VERSION"
    if [ "$TMP_VERSION" -gt "$PKG_VER_MIN" ] || [ "$TMP_VERSION" = "$PKG_VER_MIN" ]
    then
      if [ "$PKG_VER_MAX" = "latest" ] || [ "$TMP_VERSION" -lt "$PKG_VER_MAX" ] || [ "$TMP_VERSION" = "$PKG_VER_MAX" ]
      then
        echo "$TMP_NAME-$TMP_PLATFORM-$TMP_VERSION"
      fi
    fi
  done
}

