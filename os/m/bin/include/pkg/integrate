        log_trace "link remove $INSTALL_DIR/$CMD_PATH - $CMD_DIR/$PKG_PLATFORM/$CMD_ALIAS"
        rm -f "$CMD_DIR/$PKG_PLATFORM/$CMD_ALIAS"
      fi
      IFS=$'\n'
