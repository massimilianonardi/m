#!/bin/sh

#-------------------------------------------------------------------------------

if [ "$1" = "--help" ] || [ "$1" = "--info" ] || [ "$1" = "--version" ]
then
  . m-args-common-commands.lib
  ARGS_PARSE_COMMAND="args_${1#--}"
  shift
  set -- "$ARGS_PARSE_COMMAND" "$@"
  unset ARGS_PARSE_COMMAND
  "$@"

  exit 0
fi

#-------------------------------------------------------------------------------

[ -z "$ARGS_FORMAT" ] && ARGS_FORMAT="exact"

case "$ARGS_FORMAT" in
  "exact") true;;
  *) exit 1;;
esac

. m-args-parse-format-${ARGS_FORMAT}.lib

#-------------------------------------------------------------------------------
