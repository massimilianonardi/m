#!/bin/sh

#https://github.com/ko1nksm/readlinkf/blob/master/readlinkf.sh
#-------------------------------------------------------------------------------

read()
{
  if [ -L "$1" ]
  then
    LINK="$1"
#    TARGET=$(ls -ld -- "$LINK" 2>/dev/null)
    TARGET=$(ls -ld -- "$LINK")
    TARGET=${TARGET#*" $LINK -> "}
  else
    TARGET="$1"
  fi
}

#-------------------------------------------------------------------------------

_resolve()
{
  FOLLOW_SYMLINKS="$1"
  shift

  read "$@"

  if [ "$TARGET" = "${TARGET#/}" ]
  then
    if [ -L "$LINK" ] && [ -f "$LINK" ]
    then
      TARGET="$(dirname "$LINK")/$TARGET"
    fi
  fi

  if [ -d "$TARGET" ]
  then
    TARGET="$(cd $FOLLOW_SYMLINKS -- "$TARGET" && pwd $FOLLOW_SYMLINKS)"
  else
    TARGET="$(cd $FOLLOW_SYMLINKS -- "${TARGET%/*}" && pwd $FOLLOW_SYMLINKS)/${TARGET##*/}"
  fi
}

#-------------------------------------------------------------------------------

resolve()
{
  _resolve -L "$@"
}

#-------------------------------------------------------------------------------

resolveall()
{
  _resolve -P "$@"
}

#-------------------------------------------------------------------------------

main()
{
  if [ "$#" -lt "2" ]
  then
    exit 1
  fi

  case "$1" in
    "read") true;;
    "resolve") true;;
    "resolveall") true;;
    *) exit 1;;
  esac

  "$@"

  echo "$TARGET"
}

#-------------------------------------------------------------------------------

#. m.lib.sh
main "$@"

#-------------------------------------------------------------------------------
